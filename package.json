{
	"name": "convert-vapid-public-key",
	"version": "2.0.0",
	"type": "module",
	"engines": {
		"node": "^22.0.0 || ^24.0.0"
	},
	"exports": {
		"types": "./target/src/index.d.ts",
		"default": "./target/src/index.js"
	},
	"author": "Christian Rackerseder <git@echooff.de>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/screendriver/convert-vapid-public-key.git"
	},
	"bugs": {
		"url": "https://github.com/screendriver/convert-vapid-public-key/issues"
	},
	"homepage": "https://github.com/screendriver/convert-vapid-public-key#readme",
	"keywords": [
		"vapid",
		"push-notifications",
		"web-push",
		"urlBase64ToUint8Array"
	],
	"files": [
		"target/src/**/*.js",
		"target/src/**/*.js.map",
		"target/src/**/*.d.ts"
	],
	"scripts": {
		"clean": "rm -rf target",
		"compile": "tsc --build",
		"lint": "eslint . --ext '.ts'",
		"test:unit": "mocha --config mocha.config.cjs",
		"test:unit:coverage": "c8 npm run test:unit",
		"release:dry": "release-it --dry-run --no-npm",
		"release": "release-it"
	},
	"devDependencies": {
		"@types/atob": "2.1.4",
		"@types/mocha": "10.0.10",
		"@types/node": "24.12.2",
		"@typescript-eslint/eslint-plugin": "7.18.0",
		"@typescript-eslint/parser": "7.18.0",
		"atob": "2.1.2",
		"auto-changelog": "2.5.1",
		"c8": "11.0.0",
		"esbuild": "0.28.0",
		"eslint": "8.57.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.5",
		"mocha": "11.7.5",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "6.0.3"
	}
}
